# Shopify Configuration
# Get these from your Shopify Admin > Settings > Apps and sales channels > Develop apps

# Your Shopify store domain (e.g., your-store.myshopify.com)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Storefront API Access Token (create in Shopify Admin > Settings > Apps > Develop apps > Create an app > Configure Storefront API)
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-access-token

# For private app (legacy method)
SHOPIFY_ADMIN_ACCESS_TOKEN=your-admin-access-token

# WhatsApp number for chat (with country code, no +)
NEXT_PUBLIC_WHATSAPP_NUMBER=1234567890